# Fabric test network (host)
FABRIC_SAMPLES_DIR=./fabric-samples
FABRIC_VERSION=2.5.12
CHANNEL_NAME=mychannel
CHAINCODE_NAME=referendum
CHAINCODE_VERSION=1.0
CHAINCODE_SEQUENCE=1

# Fabric gateway service
FABRIC_SERVICE_PORT=5000
FABRIC_CCP_PATH=./config/connection-org1.json
FABRIC_WALLET_PATH=./fabric_service/wallet
FABRIC_IDENTITY=admin
FABRIC_DISCOVERY_AS_LOCALHOST=true

# Django backend
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
FABRIC_SERVICE_URL=http://localhost:5000

# React frontend (Vite)
VITE_API_BASE_URL=http://localhost:8000/api
